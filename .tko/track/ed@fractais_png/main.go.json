            "label": "2026-04-08_14-54-59",
            "content": "package main\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n)\n\nfunc ri(inf, sup int) float64 {\n\treturn float64(rand.Intn(sup-inf+1) + inf)\n}\n\nfunc circulo(pen *Pen, raio float64, nivel int) {\n\tif nivel == 0 {\n\t\treturn\n\t}\n\n\tpen.DrawCircle(raio)\n\t\n\tfor i := 0; i < 6; i++ {\n\t\tpen.Right(60)\n\n\t\tpen.Up()\n\t\tpen.Walk(raio)\n\t\tpen.Down()\n\n\t\tpen.Right(90)\n\n\t\tcirculo(pen, raio*0.35, nivel-1)\n\n\t\tpen.Left(90)\n\t\tpen.Up()\n\t\tpen.Walk(-raio)\n\t\tpen.Down()\n\t}\n}\n\nfunc main() {\n\tpen := NewPen(1200, 1200)\n\tpen.SetPosition(600, 600)\n\tcirculo(pen, 320, 5)\n\tpen.SavePNG(\"tree.png\")\n\tfmt.Println(\"PNG file created successfully.\")\n}\n",
